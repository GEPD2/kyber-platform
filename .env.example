# ─────────────────────────────────────────────────────────────────────────────
#  CRYSTALS-Kyber Training Platform — Environment Variables
#  Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── APP ──────────────────────────────────────────────────────────────────────
APP_NAME="CRYSTALS-Kyber Training"
APP_ENV=production          # production | development
DEBUG=false
ALLOWED_ORIGINS_RAW=http://localhost,http://localhost:80

# ── SECRET KEYS (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32
JWT_SECRET=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MYSQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=kyber_training
MYSQL_USER=kyber_app
MYSQL_PASSWORD=CHANGE_ME_APP_PASSWORD
DB_HOST=mysql
DB_PORT=3306
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100      # requests per window
RATE_LIMIT_WINDOW=60         # window in seconds
ANSWER_SUBMIT_LIMIT=30       # answer submissions per minute per user

# ── SECURITY ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
CSRF_TOKEN_EXPIRE=3600

# ── TLS (for future HTTPS — set to true when certs are in ./nginx/certs/) ───
TLS_ENABLED=false
# TLS_CERT=/etc/nginx/certs/fullchain.pem
# TLS_KEY=/etc/nginx/certs/privkey.pem
